# Point the Next.js app at your Zoctor FastAPI backend (Mem_Update).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Enable FastAPI integration: auth (/api/users/auth/*), profiles (/api/paid-reports/*),
# PDF extract + summary + chat (/api/v1/*).
NEXT_PUBLIC_USE_FASTAPI=1

# Optional: JWT secret on the Python side must match production (set in Mem_Update env).
# JWT_SECRET=your-long-random-secret
