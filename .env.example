# Point the Next.js app at your Zoctor FastAPI backend (Mem_Update).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Enable FastAPI integration: auth (/api/users/auth/*), profiles (/api/paid-reports/*),
# PDF extract + summary + chat (/api/v1/*).
NEXT_PUBLIC_USE_FASTAPI=1

# Optional: JWT secret on the Python side must match production (set in Mem_Update env).
# JWT_SECRET=your-long-random-secret

# Health Reveal (Tier-1 server PDF) uses /api/paid-reports on the FastAPI app; no Stripe required in dev.

# Google sign-in: create an OAuth 2.0 Client ID (Web application) in Google Cloud Console,
# add authorized JavaScript origins (e.g. http://localhost:3000) and authorized redirect URIs if needed.
# Use the same Client ID string here and as GOOGLE_OAUTH_CLIENT_ID in Mem_Update (.env).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
